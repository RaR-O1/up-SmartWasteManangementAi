{
  "name": "smart-waste-management",
  "version": "1.0.0",
  "description": "AI-Powered Smart Waste Management System",
  "main": "backend/server.js",
  "scripts": {
    "dev": "nodemon backend/server.js",
    "start": "node backend/server.js",
    "frontend": "cd frontend && python -m http.server 3000",
    "setup": "npm install && npm run db:setup",
    "db:setup": "node backend/database/setup.js",
    "db:seed": "node backend/database/seed.js",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && echo 'Frontend built'",
    "test": "npm run test:backend && npm run test:frontend",
    "docker:build": "docker build -t smartwaste .",
    "docker:run": "docker-compose up"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.4",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.5.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
